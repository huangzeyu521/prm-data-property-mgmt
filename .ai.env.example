# 大模型接入配置模板 —— 复制为 .ai.env 并填入真实 KEY(.ai.env 已加入 .gitignore,不会被提交)
# 用法: bash scripts/restart-with-ai.sh   (读取 .ai.env 重建三服务容器,所有 11 个 AI 触点切换为真实 qwen 调用)

# 开关:qwen=真实调用阿里云百炼;stub=本地规则桩(离线/测试)
PRM_AI_PROVIDER=qwen

# 模型:统一 qwen3.7-max 最新快照
QWEN_MODEL_NAME=qwen3.7-max-2026-06-08

# 阿里云百炼 API KEY(必填,sk- 开头;泄露须立即在百炼控制台轮换)
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
